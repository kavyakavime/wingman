# ── Local dev (.env.local) ──────────────────────────────────────────────────
# Run `npx convex dev` then copy these values into .env.local:
#
# CONVEX_DEPLOYMENT=local:local-<team>-<project>   # written by `npx convex dev`
# NEXT_PUBLIC_CONVEX_URL=http://127.0.0.1:3210
# NEXT_PUBLIC_CONVEX_SITE_URL=http://127.0.0.1:3211

# ── Vercel production (set in Vercel dashboard, NOT in .env.local) ──────────
# NEXT_PUBLIC_CONVEX_URL=https://formal-monitor-473.convex.cloud
# NEXT_PUBLIC_CONVEX_SITE_URL=https://formal-monitor-473.convex.site

NEXT_PUBLIC_CONVEX_URL=

# All THIRD-PARTY API KEYS — FIBER_API_KEY, ORANGESLICE_API_KEY, OPENAI_API_KEY,
# CURSOR_API_KEY — are NOT set here. They go into Convex's own env vars via:
#   npx convex env set KEY value
# since they're only ever used server-side inside Convex actions, never bundled
# into client code.
