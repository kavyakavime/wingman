# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.log
*.pem

# secrets (never commit)
/secrets/
/credentials/
# Orange Slice CLI API key (default path: ~/.config/orangeslice/config.json)
.config/orangeslice/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# convex local dev state
.convex/

# typescript
*.tsbuildinfo
next-env.d.ts
